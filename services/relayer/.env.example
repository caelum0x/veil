# Veil relayer / ASP coordinator configuration
PORT=8787

# Network + deployment manifest (written by scripts/deploy-pools.sh)
VEIL_NETWORK=testnet
# VEIL_MANIFEST=../../deployments/testnet.json   # defaults to deployments/<network>.json

# stellar CLI identity that holds the admin key for the pools (signs set_association_root).
# Defaults to the adminIdentity recorded in the manifest.
# VEIL_ADMIN_IDENTITY=veil_admin
